{
  "name": "capsulemap",
  "version": "0.1.2",
  "description": "Repo-native handoff maps for coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "CapsuleMap contributors",
  "homepage": "https://github.com/tygh89071388/CapsuleMap#readme",
  "bugs": {
    "url": "https://github.com/tygh89071388/CapsuleMap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tygh89071388/CapsuleMap.git"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "handoff",
    "codemap",
    "local-first",
    "developer-tools"
  ],
  "files": [
    "bin/",
    "src/",
    "docs/DESIGN-NOTES.md",
    "docs/DESIGN-NOTES.zh-TW.md",
    "docs/SEARCH-GRAPH-ROADMAP.md",
    "docs/SEARCH-GRAPH-ROADMAP.zh-TW.md",
    "README.zh-TW.md"
  ],
  "bin": {
    "capsulemap": "bin/capsulemap.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "node --check bin/capsulemap.mjs && node --check src/local-judge.mjs && node --check src/project-scan.mjs && node --check src/writer.mjs",
    "test": "node --test tests/*.test.mjs",
    "demo": "node bin/capsulemap.mjs init . && node bin/capsulemap.mjs prompt ."
  },
  "engines": {
    "node": ">=20"
  }
}
